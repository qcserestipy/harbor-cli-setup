{
  "name": "harbor-cli-setup",
  "version": "0.0.2",
  "description": "A GitHub Action that downloads, verifies, and installs the Harbor CLI tool from official GitHub releases, or optionally builds it from the latest main branch.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && ncc build dist/index.js -o dist --minify --no-source-map-register",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "test": "echo \"No tests configured yet\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qcserestipy/harbor-cli-setup.git"
  },
  "keywords": [
    "github-action",
    "harbor",
    "harbor-cli",
    "cli",
    "setup"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/qcserestipy/harbor-cli-setup/issues"
  },
  "homepage": "https://github.com/qcserestipy/harbor-cli-setup#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^1.1.1",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vercel/ncc": "^0.38.4",
    "husky": "^9.1.7",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  }
}
